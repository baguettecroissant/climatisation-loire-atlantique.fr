---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import StepsForm from '../components/StepsForm.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';

const title = "Climatisation & Pompe à Chaleur Loire-Atlantique (44) | Artisans RGE 2026";
const description = "Climatisation réversible & PAC air-air en Loire-Atlantique (44). Obtenez 3 devis gratuits d'installateurs qualifiés RGE. Confort atlantique et économies.";

// Show top 6 communes on home page
const featuredCommunes = communes.slice(0, 6);

// Fetch guides for internal linking
const guides = await getCollection('guides');
---

<Layout title={title} description={description} activeTab="home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container two-column-layout">
      <div>
        <span class="badge-pill" style="background:var(--secondary); border-color:var(--border-color); margin-bottom:15px; color:white;">
          🌿 Confort 4 saisons — Votre clim réversible RGE en 48h
        </span>
        <h1 style="font-size:42px; line-height:1.2; margin-bottom:20px; font-weight:800;">
          Climatisation réversible en Loire-Atlantique (44)
        </h1>
        <p style="font-size:18px; margin-bottom:25px; opacity:0.95; line-height:1.6;">
          Les maisons nantaises traditionnelles, les villas de l'estuaire ou du littoral et les pavillons résidentiels périurbains méritent le meilleur du confort thermique. Équipez votre logement d'un split mural discret ou d'un gainable totalement invisible. Profitez d'une fraîcheur immédiate face à la chaleur humide atlantique et divisez vos factures de chauffage par 3 en hiver.
        </p>

        <div style="background:rgba(255,255,255,0.08); border:1.5px solid rgba(255,255,255,0.15); border-radius:15px; padding:20px; font-size:15px; line-height:1.6;">
          <strong>📊 Le marché du génie climatique en Loire-Atlantique :</strong>
          <ul style="list-style:none; margin-top:10px; display:flex; flex-direction:column; gap:8px;">
            <li>💧 Climat : <span class="leaf-float">🌿</span> Humidité marine constante qui amplifie l'inconfort estival (records à plus de 40°C à Nantes) et hivers historiquement chauffage-only.</li>
            <li>🛠️ Artisans certifiés : <strong>Installateurs RGE Qualipac</strong> et techniciens agréés fluides du 44.</li>
            <li>⏱️ Devis : <strong>Étude de dimensionnement et visite technique gratuites</strong> sous 24h.</li>
          </ul>
        </div>
      </div>

      <div>
        <StepsForm />
      </div>
    </div>
  </section>

  <!-- Interactive Power Simulator -->
  <section style="padding:60px 0; background:white;">
    <div class="container" style="max-width:800px; text-align:center;">
      <h2 style="color:var(--primary); margin-bottom:15px;">Simulateur de puissance Climatisation</h2>
      <p style="color:var(--text-muted); margin-bottom:35px; font-size:16px;">
        Calculez la puissance en kW recommandée pour climatiser votre maison ou appartement en Loire-Atlantique (44).
      </p>

      <div style="background:var(--primary-light); border:2px solid var(--border-color); padding:30px; border-radius:var(--radius-md); text-align:left; box-shadow:var(--shadow-sm);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
          <div class="form-group">
            <label for="sim-surface">Surface à équiper (m²)</label>
            <input type="number" id="sim-surface" class="form-control" value="45" min="10" max="250" />
          </div>
          <div class="form-group">
            <label for="sim-isolation">Qualité de l'isolation du bâti</label>
            <select id="sim-isolation" class="form-control" style="padding:0 15px;">
              <option value="0.8">Excellente (RE2020 / BBC / Neuf)</option>
              <option value="1.0" selected>Standard (RT2012)</option>
              <option value="1.3">Moyenne (Maison traditionnelle rénovée)</option>
              <option value="1.5">Maison nantaise en tuffeau aux murs épais</option>
            </select>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:15px;">
          <div class="form-group">
            <label for="sim-orientation">Exposition au soleil / Littoral</label>
            <select id="sim-orientation" class="form-control" style="padding:0 15px;">
              <option value="1.0">Nord (Ombragé / Altitude bocage)</option>
              <option value="1.15" selected>Est / Ouest (Ensoleillement standard)</option>
              <option value="1.30">Sud / Front de mer (Fort ensoleillement / Humidité)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="sim-etage">Configuration des pièces</label>
            <select id="sim-etage" class="form-control" style="padding:0 15px;">
              <option value="1.0" selected>Rez-de-chaussée (Fraîcheur relative)</option>
              <option value="1.25">Sous les toits / Mansardes / Mezzanine nantaise</option>
            </select>
          </div>
        </div>

        <div style="text-align:center; margin-top:30px; border-top:1px solid var(--border-color); padding-top:25px;">
          <span style="font-size:16px; color:var(--text-muted); display:block; margin-bottom:8px;">Puissance frigorifique estimée :</span>
          <span id="sim-result" style="font-family:var(--font-mono); font-size:36px; font-weight:800; color:var(--secondary);">4.6 kW</span>
          <p style="font-size:13px; color:var(--text-muted); margin-top:8px;">
            *Calcul indicatif pour le climat de la Loire-Atlantique. Une étude thermique sur place par un pro certifié est requise avant toute installation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Split vs Gainable Comparison -->
  <section style="padding:80px 0; background:var(--primary-light);">
    <div class="container">
      <div style="text-align:center; margin-bottom:50px;">
        <h2 style="color:var(--primary); margin-bottom:15px;">Quel système pour mon habitat : Split ou Gainable ?</h2>
        <p style="color:var(--text-muted); font-size:16px; max-width:700px; margin:0 auto;">
          Comparez les caractéristiques techniques et esthétiques des deux solutions phares en Loire-Atlantique.
        </p>
      </div>

      <div style="background:white; border:2px solid var(--border-color); border-radius:var(--radius-md); overflow:hidden; box-shadow:var(--shadow-sm); overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; text-align:left; font-size:16px; min-width:600px;">
          <thead>
            <tr style="background:var(--primary); color:white;">
              <th style="padding:20px; font-weight:700; color:white;">Critère</th>
              <th style="padding:20px; font-weight:700; color:white;">Split Mural Inverter</th>
              <th style="padding:20px; font-weight:700; color:white;">Climatisation Gainable Invisible</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Impact visuel</td>
              <td style="padding:20px; color:var(--text-muted);">Bloc compact fixé au mur (apparent)</td>
              <td style="padding:20px; color:var(--text-muted);">Zéro impact (grilles ultra-discrètes intégrées au faux-plafond)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Adaptation Bâti Ancien</td>
              <td style="padding:20px; color:var(--text-muted);">Perçage direct, installation rapide</td>
              <td style="padding:20px; color:var(--text-muted);">Parfait pour préserver le cachet historique (tuffeau, pierres)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Déshumidification</td>
              <td style="padding:20px; color:var(--text-muted);">Active, régulée par télécommande</td>
              <td style="padding:20px; color:var(--text-muted);">Intégrée et couplée à un système multizone (Airzone)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Silence de fonctionnement</td>
              <td style="padding:20px; color:var(--text-muted);">Trés silencieux (niveaux d'entrée à 19 dB)</td>
              <td style="padding:20px; color:var(--text-muted);">Quasi inaudible (moteur principal déporté en combles)</td>
            </tr>
            <tr>
              <td style="padding:20px; font-weight:700; color:var(--primary);">Budget moyen posé TTC</td>
              <td style="padding:20px; font-weight:700; color:var(--secondary); font-family:var(--font-mono);">1 300 € – 2 500 €</td>
              <td style="padding:20px; font-weight:700; color:var(--secondary); font-family:var(--font-mono);">5 000 € – 11 000 €</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing section -->
  <section style="padding:80px 0; background:white;">
    <div class="container">
      <div style="text-align:center; margin-bottom:50px;">
        <h2 style="color:var(--primary); margin-bottom:15px;">Tarifs d'installation moyens en Loire-Atlantique (2026)</h2>
        <p style="color:var(--text-muted); font-size:16px; max-width:750px; margin:0 auto;">
          Découvrez la grille de prix indicatifs TTC (pose + matériel inclus) pour vos projets dans le 44.
        </p>
      </div>

      <div class="grid-3">
        <div class="card" style="text-align:center;">
          <h3 style="color:var(--primary); margin-bottom:10px;">Split Mono-Mural</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">1 300€ – 2 500€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            Une unité intérieure reliée à un compresseur extérieur. Idéal pour chauffer et rafraîchir une pièce principale ou chambre isolée.
          </p>
          <a href="/devis/" class="btn-secondary" style="width:100%;">Demander un devis</a>
        </div>

        <div class="card" style="text-align:center; border-color:var(--primary); transform: scale(1.03); box-shadow:var(--shadow-md);">
          <div style="background:var(--primary); color:white; font-size:11px; font-weight:700; text-transform:uppercase; padding:4px 10px; border-radius:10px; display:inline-block; margin-bottom:15px;">Recommandé Multi-pièces</div>
          <h3 style="color:var(--primary); margin-bottom:10px;">Multi-Split (2 à 4 zones)</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">2 500€ – 6 500€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            Un seul bloc extérieur alimentant plusieurs unités intérieures. Régulation thermique indépendante pièce par pièce.
          </p>
          <a href="/devis/" class="btn-primary" style="width:100%;">Demander un devis</a>
        </div>

        <div class="card" style="text-align:center;">
          <h3 style="color:var(--primary); margin-bottom:10px;">Climatisation Gainable</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">5 000€ – 11 000€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            Système invisible centralisé. Recommandé pour équiper de grandes maisons neuves ou rénovations haut de gamme en préservant les lignes du bâti.
          </p>
          <a href="/devis/" class="btn-secondary" style="width:100%;">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Guides & Conseils Pratiques -->
  <section style="padding:80px 0; background:white; border-top: 2px solid var(--border-color);">
    <div class="container">
      <div style="text-align:center; margin-bottom:50px;">
        <h2 style="color:var(--primary); margin-bottom:15px;">Dossiers de nos experts RGE</h2>
        <p style="color:var(--text-muted); font-size:16px; max-width:700px; margin:0 auto;">
          Retrouvez nos guides complets pour réussir votre transition thermique en Loire-Atlantique.
        </p>
      </div>

      <div class="grid-3">
        {guides.slice(0, 3).map(post => (
          <article class="card" style="display:flex; flex-direction:column; justify-content:space-between;">
            <div>
              <span class="price-tag" style="font-size:12px; font-weight:700; text-transform:uppercase; color:var(--secondary); display:block; margin-bottom:10px;">📑 Dossier technique</span>
              <h3 style="font-size:18px; margin-bottom:12px; line-height:1.4;"><a href={`/guides/${post.id}/`} style="color:var(--text); text-decoration:none;">{post.data.title}</a></h3>
              <p style="font-size:14px; color:var(--text-muted); line-height:1.6; margin-bottom:20px;">{post.data.description}</p>
            </div>
            <a href={`/guides/${post.id}/`} style="font-weight:700; color:var(--primary); text-decoration:none; font-size:14px;">Lire l'article &rarr;</a>
          </article>
        ))}
      </div>

      <div style="text-align:center; margin-top:40px;">
        <a href="/guides/" class="btn-secondary">Voir tous nos guides</a>
      </div>
    </div>
  </section>

  <!-- Local directories index -->
  <section style="padding:80px 0; background:var(--primary-light);">
    <div class="container">
      <div style="text-align:center; margin-bottom:40px;">
        <h2 style="color:var(--primary); margin-bottom:10px;">Artisans RGE actifs en Loire-Atlantique</h2>
        <p style="color:var(--text-muted); font-size:16px;">Sélectionnez votre commune pour trouver un frigoriste RGE local.</p>
      </div>

      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px;">
        {featuredCommunes.map(c => (
          <a href={`/climatisation-${c.slug}/`} style="background:white; border:1px solid var(--border-color); border-radius:12px; padding:15px; text-align:center; text-decoration:none; color:var(--text); font-weight:700; box-shadow:var(--shadow-sm); transition:var(--transition); display:block;">
            <span style="display:block; font-size:15px; color:var(--primary);">{c.nom}</span>
            <span style="font-size:12px; color:var(--text-muted); font-family:var(--font-mono); font-weight:normal;">{c.codePostal}</span>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:35px;">
        <a href="/communes/" style="font-weight:700; color:var(--primary); text-decoration:none;">→ Voir l'ensemble des {communes.length} communes desservies</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple clientside simulator logic
  document.addEventListener('DOMContentLoaded', () => {
    const surfaceInput = document.getElementById('sim-surface') as HTMLInputElement;
    const isolationSelect = document.getElementById('sim-isolation') as HTMLSelectElement;
    const orientationSelect = document.getElementById('sim-orientation') as HTMLSelectElement;
    const etageSelect = document.getElementById('sim-etage') as HTMLSelectElement;
    const resultEl = document.getElementById('sim-result');

    const recalculate = () => {
      if (!surfaceInput || !isolationSelect || !orientationSelect || !etageSelect || !resultEl) return;
      const surface = parseFloat(surfaceInput.value) || 0;
      const iso = parseFloat(isolationSelect.value) || 1;
      const exp = parseFloat(orientationSelect.value) || 1;
      const etage = parseFloat(etageSelect.value) || 1;

      // Base: 100 Watts per square meter
      const baseWatts = surface * 100;
      const totalWatts = baseWatts * iso * exp * etage;
      const kw = (totalWatts / 1000).toFixed(1);

      resultEl.textContent = `${kw} kW`;
    };

    [surfaceInput, isolationSelect, orientationSelect, etageSelect].forEach(el => {
      if (el) el.addEventListener('input', recalculate);
    });
  });
</script>
