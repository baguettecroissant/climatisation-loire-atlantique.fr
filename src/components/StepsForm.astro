---
import communes from '../data/communes.json';

interface Props {
  initialZip?: string;
  initialCommune?: string;
}

const { initialZip = "", initialCommune = "" } = Astro.props;
---

<div class="form-card" id="devis">
  <h2>Estimez le prix de votre climatisation réversible</h2>
  <p class="subtitle">Artisans RGE de Loire-Atlantique (44) - Devis gratuit sous 24h</p>

  <form id="clim-lead-form">
    <!-- Step 1: Type de climatisation -->
    <div class="step-container" id="step-1">
      <div class="form-group">
        <label>1. Quel type d'installation recherchez-vous ?</label>
        <div class="options-grid">
          <div class="option-box active" data-value="Mono-split" data-step="1">
            <span>🌿 Mono-split (1 pièce)</span>
            <span class="desc-text">Idéal pour climatiser un salon ou une chambre seule</span>
          </div>
          <div class="option-box" data-value="Multi-split" data-step="1">
            <span>🌿 Multi-split (2 à 4 pièces)</span>
            <span class="desc-text">Climatisez plusieurs chambres et votre pièce à vivre</span>
          </div>
          <div class="option-box" data-value="Gainable" data-step="1">
            <span>🌿 Gainable (Invisible)</span>
            <span class="desc-text">Intégration en faux-plafond, idéal pour les belles rénovations</span>
          </div>
          <div class="option-box" data-value="PAC réversible" data-step="1">
            <span>🌿 Pompe à chaleur air-air</span>
            <span class="desc-text">Double usage : chaud en hiver, froid en été</span>
          </div>
        </div>
        <input type="hidden" name="type_clim" id="type_clim" value="Mono-split" />
        <input type="hidden" name="cat_id" id="cat_id" value="19" />
      </div>
      <div class="form-nav">
        <button type="button" class="btn-primary next-btn" data-next="2" style="width: 100%;">Continuer &rarr;</button>
      </div>
    </div>

    <!-- Step 2: Habitation & Statut -->
    <div class="step-container" id="step-2" style="display: none;">
      <div class="form-group">
        <label>2. Quel est le type de bâtiment ?</label>
        <div class="options-grid-row">
          <div class="option-box-small active" data-value="1" data-field="type_bien" data-step="2">
            <span>🏡 Maison / Pavillon</span>
          </div>
          <div class="option-box-small" data-value="2" data-field="type_bien" data-step="2">
            <span>🏢 Appartement / Duplex</span>
          </div>
        </div>
        <input type="hidden" name="type_bien" id="type_bien" value="1" />
      </div>

      <div class="form-group" style="margin-top: 25px;">
        <label>Quel est votre statut d'occupation ?</label>
        <div class="options-grid-row">
          <div class="option-box-small active" data-value="1" data-field="situation" data-step="2b">
            <span>Propriétaire</span>
          </div>
          <div class="option-box-small" data-value="2" data-field="situation" data-step="2b">
            <span>Locataire</span>
          </div>
        </div>
        <input type="hidden" name="situation" id="situation" value="1" />
      </div>

      <div class="form-nav">
        <button type="button" class="btn-secondary prev-btn" data-prev="1">&larr; Retour</button>
        <button type="button" class="btn-primary next-btn" data-next="3">Continuer &rarr;</button>
      </div>
    </div>

    <!-- Step 3: Type de chauffage actuel -->
    <div class="step-container" id="step-3" style="display: none;">
      <div class="form-group">
        <label>3. Quel est votre système de chauffage actuel ?</label>
        <div class="options-grid">
          <div class="option-box active" data-value="Electrique" data-step="3">
            <span>⚡ Chauffage électrique</span>
            <span class="desc-text">Convecteurs ou radiateurs (factures élevées)</span>
          </div>
          <div class="option-box" data-value="Gaz" data-step="3">
            <span>🔥 Chauffage au gaz</span>
            <span class="desc-text">Chaudière individuelle ou collective</span>
          </div>
          <div class="option-box" data-value="Fioul / Bois" data-step="3">
            <span>🪵 Fioul ou bois</span>
            <span class="desc-text">Chaudière fioul ou poêle traditionnel</span>
          </div>
          <div class="option-box" data-value="Autre / Pompe a chaleur" data-step="3">
            <span>🌿 Autre / Pompe à chaleur</span>
            <span class="desc-text">Déjà équipé ou autre configuration</span>
          </div>
        </div>
        <input type="hidden" name="chauffage_actuel" id="chauffage_actuel" value="Electrique" />
      </div>

      <div class="form-nav">
        <button type="button" class="btn-secondary prev-btn" data-prev="2">&larr; Retour</button>
        <button type="button" class="btn-primary next-btn" data-next="4">Continuer &rarr;</button>
      </div>
    </div>

    <!-- Step 4: Localisation & Délai -->
    <div class="step-container" id="step-4" style="display: none;">
      <div class="form-group">
        <label for="postal_code">4. Code postal du chantier (Loire-Atlantique uniquement)</label>
        <input type="text" id="postal_code" name="postal_code" placeholder="Ex: 44000" class="form-control" required pattern="^44[0-9]{3}$" maxlength="5" value={initialZip} />
        <span class="input-tip">Doit commencer par 44 (ex : 44000 Nantes, 44600 Saint-Nazaire, 44400 Rezé, 44800 Saint-Herblain)</span>
      </div>

      <!-- Auto resolved city display -->
      <div class="form-group" id="ville-group" style="display: none;">
        <label for="ville_chantier">Ville du projet</label>
        <input type="text" id="ville_chantier" name="ville_chantier" class="form-control" placeholder="Sélectionnez votre ville" required value={initialCommune} />
      </div>

      <div class="form-group" style="margin-top: 25px;">
        <label>Délai souhaité pour votre installation</label>
        <div class="options-grid-row">
          <div class="option-box-small active" data-value="1" data-field="delais" data-step="4b">
            <span>⚡ Urgent / Canicule</span>
          </div>
          <div class="option-box-small" data-value="2" data-field="delais" data-step="4b">
            <span>📅 - de 3 mois</span>
          </div>
          <div class="option-box-small" data-value="4" data-field="delais" data-step="4b">
            <span>⏳ + de 3 mois</span>
          </div>
        </div>
        <input type="hidden" name="delais" id="delais" value="1" />
      </div>

      <div class="form-nav">
        <button type="button" class="btn-secondary prev-btn" data-prev="3">&larr; Retour</button>
        <button type="button" class="btn-primary next-btn" data-next="5">Continuer &rarr;</button>
      </div>
    </div>

    <!-- Step 5: Coordonnées de contact -->
    <div class="step-container" id="step-5" style="display: none;">
      <div class="form-group-row">
        <div class="form-group">
          <label for="prenom">Votre Prénom</label>
          <input type="text" id="prenom" name="prenom" placeholder="Jean" class="form-control" required minlength="2" />
        </div>
        <div class="form-group">
          <label for="nom">Votre Nom</label>
          <input type="text" id="nom" name="nom" placeholder="Dupont" class="form-control" required minlength="2" />
        </div>
      </div>

      <div class="form-group">
        <label for="phone">Téléphone (validation requise)</label>
        <input type="tel" id="phone" name="phone" placeholder="06 12 34 56 78" class="form-control" required pattern="^(06|07|01|02|03|04|05|09)[0-9]{8}$" maxlength="10" />
        <span class="input-tip">Un climaticien certifié RGE valide votre projet par téléphone.</span>
      </div>

      <div class="form-group">
        <label for="email">Adresse email</label>
        <input type="email" id="email" name="email" placeholder="jean.dupont@gmail.com" class="form-control" required />
      </div>

      <div class="form-group">
        <label for="adresse">Adresse complète de l'installation</label>
        <input type="text" id="adresse" name="adresse" placeholder="12 Rue Crébillon" class="form-control" required minlength="5" />
      </div>

      <!-- Errors alert wrapper -->
      <div id="form-errors" class="alert-danger" style="display: none; margin-top: 15px;"></div>

      <div class="form-nav">
        <button type="button" class="btn-secondary prev-btn" data-prev="4">&larr; Retour</button>
        <button type="submit" class="btn-primary submit-btn" style="color: white; border: none; width: auto; flex: 1;">🔥 Envoyer ma demande &rarr;</button>
      </div>
    </div>
  </form>

  <div id="form-submitting" style="display: none; text-align: center; padding: 40px 0;">
    <div class="spinner-loader"></div>
    <h3 style="font-size: 20px; font-weight: 700; color: var(--primary); margin-top: 20px;">Analyse de votre projet...</h3>
    <p style="color: var(--text-muted); font-size: 16px; margin-top: 8px;">Recherche de professionnels RGE disponibles dans votre secteur de Loire-Atlantique.</p>
  </div>
</div>

<style>
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-top: 15px;
  }
  @media (max-width: 576px) {
    .options-grid {
      grid-template-columns: 1fr;
    }
  }
  .option-box {
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 20px;
    cursor: pointer;
    background: #fff;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .option-box span {
    font-weight: 700;
    font-size: 15px;
    color: var(--text);
  }
  .option-box.active {
    border-color: var(--secondary);
    background: var(--primary-light);
  }
  .options-grid-row {
    display: flex;
    gap: 10px;
    width: 100%;
  }
  .option-box-small {
    flex: 1;
    padding: 14px;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    text-align: center;
    cursor: pointer;
    font-weight: 700;
    font-size: 16px;
    background: #fff;
    color: var(--primary);
    transition: var(--transition);
  }
  .option-box-small:hover {
    border-color: var(--secondary);
    background: var(--primary-light);
  }
  .option-box-small.active {
    border-color: var(--secondary);
    background: var(--primary-light);
    color: var(--primary);
    box-shadow: 0 0 0 1px var(--secondary);
  }
  .desc-text {
    font-size: 13px;
    font-weight: normal;
    color: var(--text-muted);
    margin-top: 6px;
    display: block;
  }
  .input-tip {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
    display: block;
  }
  .form-group-row {
    display: flex;
    gap: 15px;
  }
  .form-group-row .form-group {
    flex: 1;
  }
  .alert-danger {
    background: #fff5f5;
    border: 2px solid #feb2b2;
    color: #9b2c2c;
    padding: 12px;
    border-radius: var(--radius-sm);
    font-size: 15px;
    font-weight: 600;
  }
  .form-card {
    background: white;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 35px;
    box-shadow: var(--shadow-md);
    max-width: 550px;
    margin: 0 auto;
  }
  .form-card h2 {
    font-size: 20px;
    color: var(--primary);
    text-align: center;
    margin-bottom: 5px;
  }
  .form-card .subtitle {
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 25px;
  }
  .form-nav {
    display: flex;
    gap: 15px;
    margin-top: 30px;
  }
  .form-nav button {
    flex: 1;
  }
  .spinner-loader {
    width: 50px;
    height: 50px;
    border: 5px solid var(--border-color);
    border-top: 5px solid var(--secondary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto;
  }
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  import communes from '../data/communes.json';

  const nextBtns = document.querySelectorAll('.next-btn');
  const prevBtns = document.querySelectorAll('.prev-btn');
  const form = document.getElementById('clim-lead-form');
  const formSubmitting = document.getElementById('form-submitting');
  const formErrors = document.getElementById('form-errors');
  const pcInput = document.getElementById('postal_code') as HTMLInputElement;
  const villeGroup = document.getElementById('ville-group');
  const villeInput = document.getElementById('ville_chantier') as HTMLInputElement;

  // Box option clicks
  document.querySelectorAll('.option-box').forEach(box => {
    box.addEventListener('click', () => {
      const step = box.getAttribute('data-step');
      const value = box.getAttribute('data-value');
      
      document.querySelectorAll(`.option-box[data-step="${step}"]`).forEach(b => {
        b.classList.remove('active');
      });
      
      box.classList.add('active');
      
      if (step === '1') {
        const inputType = document.getElementById('type_clim') as HTMLInputElement;
        if (inputType) inputType.value = value || '';
      } else if (step === '3') {
        const inputChauffage = document.getElementById('chauffage_actuel') as HTMLInputElement;
        if (inputChauffage) inputChauffage.value = value || '';
      }
    });
  });

  // Small Box option clicks
  document.querySelectorAll('.option-box-small').forEach(box => {
    box.addEventListener('click', () => {
      const step = box.getAttribute('data-step');
      const value = box.getAttribute('data-value');
      const field = box.getAttribute('data-field');
      
      document.querySelectorAll(`.option-box-small[data-step="${step}"]`).forEach(b => {
        b.classList.remove('active');
      });
      box.classList.add('active');
      
      const hiddenInput = document.getElementById(field || '') as HTMLInputElement;
      if (hiddenInput) {
        hiddenInput.value = value || '';
      }
    });
  });

  // Auto-resolve city from postal code (44 prefix)
  const resolveCity = () => {
    if (!pcInput) return;
    const cpVal = pcInput.value.trim();
    if (/^44\d{3}$/.test(cpVal)) {
      const found = communes.find(c => c.codePostal === cpVal);
      if (found) {
        villeInput.value = found.nom;
        if (villeGroup) villeGroup.style.display = 'block';
        villeInput.readOnly = true;
      } else {
        if (villeGroup) villeGroup.style.display = 'block';
        villeInput.value = '';
        villeInput.readOnly = false;
      }
    } else {
      if (villeGroup) villeGroup.style.display = 'none';
      villeInput.value = '';
    }
  };

  if (pcInput) {
    pcInput.addEventListener('input', resolveCity);
    if (pcInput.value) {
      resolveCity();
    }
  }

  // Next Btn Navigation
  nextBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const nextStepId = btn.getAttribute('data-next');
      const currentStep = btn.closest('.step-container') as HTMLElement;
      
      if (nextStepId === '5') {
        const cpVal = pcInput.value.trim();
        if (!/^44\d{3}$/.test(cpVal)) {
          alert('Veuillez entrer un code postal de Loire-Atlantique valide (commençant par 44).');
          return;
        }
        if (!villeInput.value.trim()) {
          alert('Veuillez spécifier la ville.');
          return;
        }
      }

      if (currentStep) currentStep.style.display = 'none';
      const targetStep = document.getElementById(`step-${nextStepId}`);
      if (targetStep) targetStep.style.display = 'block';
    });
  });

  // Prev Btn Navigation
  prevBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const prevStepId = btn.getAttribute('data-prev');
      const currentStep = btn.closest('.step-container') as HTMLElement;
      
      if (currentStep) currentStep.style.display = 'none';
      const targetStep = document.getElementById(`step-${prevStepId}`);
      if (targetStep) targetStep.style.display = 'block';
    });
  });

  // Form submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (formErrors) {
      formErrors.style.display = 'none';
      formErrors.innerHTML = '';
    }

    const formData = new FormData(form as HTMLFormElement);
    const catIdVal = Number((document.getElementById('cat_id') as HTMLInputElement)?.value || 19);
    
    const typeBienLabel = (document.getElementById('type_bien') as HTMLInputElement)?.value === '1' ? 'Maison/Pavillon' : 'Appartement';
    const statusLabel = (document.getElementById('situation') as HTMLInputElement)?.value === '1' ? 'Propriétaire' : 'Locataire';
    const typeClimLabel = (document.getElementById('type_clim') as HTMLInputElement)?.value || 'Mono-split';
    const chauffageLabel = (document.getElementById('chauffage_actuel') as HTMLInputElement)?.value || 'Electrique';
    
    const payload = {
      nom: (formData.get('nom') as string || '').trim(),
      prenom: (formData.get('prenom') as string || '').trim(),
      email: (formData.get('email') as string || '').trim(),
      tel: (formData.get('phone') as string || '').trim(),
      adresse: (formData.get('adresse') as string || '').trim(),
      cp: (formData.get('postal_code') as string || '').trim(),
      ville: (formData.get('ville_chantier') as string || '').trim(),
      catId: catIdVal,
      typeBien: (document.getElementById('type_bien') as HTMLInputElement)?.value || '1',
      situation: (document.getElementById('situation') as HTMLInputElement)?.value || '1',
      chauffageActuel: `Clim: ${typeClimLabel}, Chauffage actuel: ${chauffageLabel}, Logement: ${typeBienLabel}, Statut: ${statusLabel}`,
      delais: (document.getElementById('delais') as HTMLInputElement)?.value || '2',
      pageUrl: window.location.href
    };

    const step5 = document.getElementById('step-5') as HTMLElement;
    if (step5) step5.style.display = 'none';
    if (formSubmitting) formSubmitting.style.display = 'block';

    try {
      const response = await fetch('/api/lead', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload)
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        throw new Error(data.errors?.join('<br/>') || 'Une erreur est survenue lors de la soumission de votre projet.');
      }

      window.location.href = `/confirmation?devis_id=${data.devis_id}&devis_hash=${data.devis_hash}&prenom=${encodeURIComponent(payload.prenom)}&ville=${encodeURIComponent(payload.ville)}&cat=${payload.catId}`;

    } catch (err: any) {
      console.error(err);
      
      if (formSubmitting) formSubmitting.style.display = 'none';
      if (step5) step5.style.display = 'block';
      
      if (formErrors) {
        formErrors.style.display = 'block';
        formErrors.innerHTML = err.message || 'Une erreur est survenue lors de l\'envoi du devis. Veuillez réessayer.';
      }
    }
  });
</script>
