---
import config from '../data/config.json';

interface Props {
  type: 'LocalBusiness' | 'FAQPage';
  data: any;
}

const { type, data } = Astro.props;

let schemaJson = "";

if (type === 'LocalBusiness') {
  schemaJson = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": data.name || config.brandName,
    "description": data.description || `Installation de climatisation réversible et pompes à chaleur RGE en ${config.department} (${config.departmentCode}).`,
    "url": `https://${config.domain}`,
    "telephone": "+33240000000",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": data.locality || config.mainCity,
      "postalCode": data.postalCode || `${config.departmentCode}000`,
      "addressRegion": "Pays de la Loire",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": data.lat || 47.2184,
      "longitude": data.lon || -1.5536
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      "opens": "08:00",
      "closes": "19:00"
    }
  });
} else if (type === 'FAQPage') {
  schemaJson = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": data.map((item: any) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  });
}
---

<script type="application/ld+json" set:html={schemaJson} />
